{
  "appId": "com.example.food",
  "appName": "外卖应用",
  "homeUrl": "https://food.example.com",
  "allowedDomains": [
    "food.example.com",
    "api.food.example.com"
  ],
  "enabledFeatures": [
    "device",
    "camera",
    "location",
    "share",
    "network"
  ],
  "theme": {
    "statusBarColor": "#FFFF9800",
    "toolbarColor": "#FFFF9800",
    "toolbarTitleColor": "#FFFFFFFF",
    "showToolbar": true,
    "showBackButton": true,
    "showCloseButton": false
  },
  "networkSecurity": {
    "allowCleartext": false,
    "trustedDomains": []
  },
  "webview": {
    "javaScriptEnabled": true,
    "domStorageEnabled": true,
    "databaseEnabled": true,
    "cacheEnabled": true,
    "userAgentSuffix": "WebBox-Food/1.0",
    "defaultZoom": 1.0,
    "minZoom": 0.5,
    "maxZoom": 2.0,
    "pageLoadTimeout": 30000
  }
}
