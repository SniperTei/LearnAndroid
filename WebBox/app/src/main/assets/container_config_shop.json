{
  "appId": "com.example.shop",
  "appName": "商城应用",
  "homeUrl": "https://shop.example.com",
  "allowedDomains": [
    "shop.example.com",
    "api.shop.example.com"
  ],
  "enabledFeatures": [
    "device",
    "camera",
    "share",
    "clipboard",
    "network",
    "location"
  ],
  "theme": {
    "statusBarColor": "#FFE91E63",
    "toolbarColor": "#FFE91E63",
    "toolbarTitleColor": "#FFFFFFFF",
    "showToolbar": true,
    "showBackButton": true,
    "showCloseButton": false
  },
  "networkSecurity": {
    "allowCleartext": false,
    "trustedDomains": []
  },
  "webview": {
    "javaScriptEnabled": true,
    "domStorageEnabled": true,
    "databaseEnabled": true,
    "cacheEnabled": true,
    "userAgentSuffix": "WebBox-Shop/1.0",
    "defaultZoom": 1.0,
    "minZoom": 0.5,
    "maxZoom": 2.0,
    "pageLoadTimeout": 30000
  }
}
