{
  "appId": "com.webbox.example",
  "appName": "示例应用",
  "homeUrl": "https://example.com",
  "allowedDomains": [
    "example.com",
    "api.example.com"
  ],
  "enabledFeatures": [
    "device",
    "camera",
    "location",
    "share",
    "clipboard",
    "network"
  ],
  "theme": {
    "statusBarColor": "#FF000000",
    "toolbarColor": "#FFFFFFFF",
    "toolbarTitleColor": "#FF000000",
    "showToolbar": true,
    "showBackButton": true,
    "showCloseButton": false
  },
  "networkSecurity": {
    "allowCleartext": false,
    "trustedDomains": []
  },
  "webview": {
    "javaScriptEnabled": true,
    "domStorageEnabled": true,
    "databaseEnabled": true,
    "cacheEnabled": true,
    "userAgentSuffix": "WebBox/1.0",
    "defaultZoom": 1.0,
    "minZoom": 0.5,
    "maxZoom": 2.0,
    "pageLoadTimeout": 30000
  }
}
